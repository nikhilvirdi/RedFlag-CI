generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model User {
  id           String       @id @default(uuid())
  githubId     String       @unique
  email        String?      @unique
  name         String?
  avatarUrl    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  repositories    Repository[]
  outboundWebhooks OutboundWebhook[]
  ruleSuggestions  RuleSuggestion[]
  apiQuotas        ApiQuota[]
}

model Repository {
  id          String       @id @default(uuid())
  githubRepoId String      @unique
  name        String
  fullName    String
  url         String
  isPrivate   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  userId              String
  owner               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  scanResults         ScanResult[]
  notificationConfigs NotificationConfig[]
}

model ScanResult {
  id            String       @id @default(uuid())
  pullRequestId String
  commitSha     String
  status        ScanStatus   @default(PENDING)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  repositoryId  String
  repository    Repository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  riskScore     RiskScore?
  findings      Finding[]
}

enum ScanStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model RiskScore {
  id               String       @id @default(uuid())
  totalScore       Float
  classification   RiskLevel
  contributionData Json

  scanResultId     String       @unique
  scanResult       ScanResult   @relation(fields: [scanResultId], references: [id], onDelete: Cascade)
}

enum RiskLevel {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  CLEAN
}

model Finding {
  id             String       @id @default(uuid())
  category       String
  description    String
  file           String
  lineNumber     Int?
  severity       RiskLevel
  confidence     ConfidenceLevel
  codeSnippet    String?

  scanResultId   String
  scanResult     ScanResult   @relation(fields: [scanResultId], references: [id], onDelete: Cascade)

  remediation    Remediation?
}

enum ConfidenceLevel {
  HIGH
  MEDIUM
  LOW
}

model Remediation {
  id             String       @id @default(uuid())
  type           RemediationType
  correctedCode  String?
  recommendation String?

  findingId      String       @unique
  finding        Finding      @relation(fields: [findingId], references: [id], onDelete: Cascade)
}

enum RemediationType {
  AUTOMATIC
  GUIDED
}

model CodeEmbedding {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  repositoryId String
  findingType  String
  file         String
  codeSnippet  String
  embedding    Unsupported("vector(1536)")
  scanResultId String
  createdAt    DateTime @default(now())

  @@index([repositoryId])
}

model FalsePositive {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  repositoryId String
  findingType  String
  file         String
  codeSnippet  String
  embedding    Unsupported("vector(1536)")
  dismissedBy  String
  createdAt    DateTime @default(now())

  @@index([repositoryId, findingType])
}

model NotificationConfig {
  id           String   @id @default(uuid())
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  platform     NotificationPlatform
  webhookUrl   String
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([repositoryId, platform])
}

enum NotificationPlatform {
  SLACK
  DISCORD
}

model OutboundWebhook {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url          String
  secret       String
  events       String[]
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model RuleSuggestion {
  id          String             @id @default(uuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String
  category    String
  pattern     String
  severity    RiskLevel
  status      RuleSuggestionStatus @default(PENDING)
  reviewNote  String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

enum RuleSuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

model ApiQuota {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodStart  DateTime
  periodEnd    DateTime
  requestCount Int      @default(0)
  scanCount    Int      @default(0)
  requestLimit Int      @default(1000)
  scanLimit    Int      @default(100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, periodStart])
  @@index([userId])
}

model ScheduledScanLog {
  id           String              @id @default(uuid())
  repositoryId String
  status       ScheduledScanStatus @default(STARTED)
  startedAt    DateTime            @default(now())
  completedAt  DateTime?

  @@index([repositoryId])
  @@index([status])
}

enum ScheduledScanStatus {
  STARTED
  COMPLETED
  FAILED
}
